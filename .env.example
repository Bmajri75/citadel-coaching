# Stripe (clés disponibles sur https://dashboard.stripe.com/apikeys)
VITE_STRIPE_PUBLIC_KEY=pk_live_...       # Clé publique (frontend)
STRIPE_SECRET_KEY=sk_live_...            # Clé secrète (backend Vercel uniquement)

# URL de votre site (pour la redirection après paiement)
VITE_SITE_URL=https://votre-site.vercel.app

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# EmailJS
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
